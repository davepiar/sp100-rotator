# Credentials (never commit)
.alpaca/
*.env
.env.*
credentials

# Claude local settings (machine-specific permissions)
.claude/settings.local.json

# Claude worktrees (git plumbing, not source)
.claude/worktrees/

# Runtime state & data — ignore contents but allow specific seeds via !
# (cannot re-include children of an ignored parent dir; use state/* not state/)
state/*
!state/strategy_params.json
!state/postmortem_outcomes.jsonl
!state/trade_log.jsonl

data/snapshots/
data/reports/
data/weekly/
data/monthly/

# Claude memory files (personal notes on user/project)
.claude/memory/

# Logs and caches
*.log
.cache/

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
venv/
.venv/

# Node
node_modules/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
